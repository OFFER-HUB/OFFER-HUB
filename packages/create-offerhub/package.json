{
  "name": "create-offer-hub-orchestrator",
  "version": "1.0.0",
  "description": "Interactive installer for OFFER-HUB Orchestrator — sets up environment, database, and initial API key",
  "type": "module",
  "bin": {
    "create-offer-hub-orchestrator": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
